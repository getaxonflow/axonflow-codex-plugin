{
  "description": "AxonFlow governance hooks — automatic policy enforcement for tool calls. Copy this file to ~/.codex/hooks.json and update script paths to your clone location, or use as a template.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|exec_command|shell",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/pre-tool-check.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|exec_command|shell",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/post-tool-audit.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
