{
  "description": "AxonFlow governance hooks — automatic policy enforcement for Bash tool calls. Update paths after cloning.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/saurabhjain/Development/axonflow-codex-plugin/scripts/pre-tool-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/saurabhjain/Development/axonflow-codex-plugin/scripts/post-tool-audit.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
