{
  "description": "AxonFlow governance hooks — automatic policy enforcement for Bash tool calls",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_PLUGIN_ROOT}/scripts/pre-tool-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_PLUGIN_ROOT}/scripts/post-tool-audit.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
